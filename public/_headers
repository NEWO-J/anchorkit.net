# Security headers for Cloudflare Pages / Netlify deployments.
# GitHub Pages does not support custom HTTP response headers — these only
# take effect if the site is served through Cloudflare Pages or Netlify.
# Headers that cannot be set via meta tag (HSTS, X-Frame-Options,
# X-Content-Type-Options, Referrer-Policy) are listed here.

# Long-term cache for hashed assets (JS/CSS bundles get content-hashed filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Video, 3D models, and textures — stable filenames, cache aggressively
/background.mp4
  Cache-Control: public, max-age=31536000, immutable
/anchor.glb
  Cache-Control: public, max-age=31536000, immutable
/phone_final.glb
  Cache-Control: public, max-age=31536000, immutable
/phone_web.glb
  Cache-Control: public, max-age=31536000, immutable
/phone_v2.glb
  Cache-Control: public, max-age=31536000, immutable
/phone_v3.glb
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.JPG
  Cache-Control: public, max-age=31536000, immutable

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://api.anchorkit.net; script-src 'self' 'wasm-unsafe-eval'; worker-src blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; object-src 'none'; frame-ancestors 'none'
  Permissions-Policy: camera=(), microphone=(), geolocation=()
